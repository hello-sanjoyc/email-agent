// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid()) @db.Uuid
  name String @db.VarChar(100)
  email String @unique @db.VarChar(128)
  phone String? @db.VarChar(128)
  password String @db.VarChar(255)
  isActive Boolean @default(true) @db.Boolean @map("is_active")
  isAutomationActive Boolean @default(true) @db.Boolean @map("is_automation_active")
  aiResponseTone AIResponseTone @default(PROFESSIONAL) @map("ai_response_tone")
  aiServiceName String @db.VarChar(50) @default("gemini") @map("ai_service_name")
  lastAutomationRanAt DateTime? @map("last_automation_ran_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  refreshTokens RefreshToken[]
  passResetTokens PassResetToken[]
  emailAccounts EmailAccount[]
  calendarAccounts CalendarAccount[]
  subscriptions Subscription[]
  emailActivities EmailActivity[]
  payments Payment[]
  @@map("users")
  @@index([email])
  @@index([phone])
}

model RefreshToken {
  id String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid @map("user_id")
  token String @db.Text @unique
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean @db.Boolean @default(false) @map("is_revoked")

  userAgent String? @db.VarChar(100) @map("user_agent")
  ipAddress String? @db.VarChar(100) @map("ip_address")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
  @@index([userId,token]) 
}

model PassResetToken {
  id String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid @map("user_id")
  token String @db.Text @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("pass_reset_tokens")
  @@index([userId])
}

model EmailAccount {
  id String @id @db.Uuid @default(uuid())
  userId String @db.Uuid @map("user_id")
  emailAddress String @db.VarChar(150) @unique @map("email_address")
  appPassword String? @db.Text @map("app_password")
  authId String? @db.Text @map("auth_id")
  accessToken String? @db.Text @map("access_token")
  refreshToken String? @db.Text @map("refresh_token")
  smtpHost String? @db.VarChar(100) @map("smtp_host")
  smtpPort Int? @db.Integer @map("smtp_port")
  imapHost String? @db.VarChar(100) @map("imap_host")
  imapPort Int? @db.Integer @map("imap_port")
  provider String @db.VarChar(80) @default("custom") @map("provider")
  priorityWeight Int @db.Integer @default(100) @map("priority_weight")
  isActive Boolean @db.Boolean @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  emailActivity EmailActivity[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_accounts")
}

model CalendarAccount {
  id String @id @db.Uuid @default(uuid())
  userId String @db.Uuid @map("user_id")
  emailAddress String @db.VarChar(150) @unique @map("email_address")  
  authId String? @db.Text @map("auth_id")
  accessToken String? @db.Text @map("access_token")
  refreshToken String? @db.Text @map("refresh_token")  
  provider String @db.VarChar(80) @default("custom") @map("provider")
  isActive Boolean @db.Boolean @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("calendar_accounts")
}

model SubscriptionPlan {
  id String @id @db.Uuid @default(uuid()) @map("id")
  name String @db.VarChar(100) @map("name")
  gatewayPlanId String? @db.Text @unique @map("gateway_plan_id")
  billingInterval BillingInterval @map("billing_interval")
  quota Int @db.Integer @map("quota")
  price Decimal @db.Decimal(10,2) @map("price")
  maxEmailsPerRun Int @db.Integer @map("max_emails_per_run")
  gatewayTotalCount Int? @db.Integer @map("gateway_total_count")
  gatewayCustomerNotify Int? @db.Integer @map("gateway_customer_notify")
  createdAt DateTime @default(now()) @map("created_at")
  subscriptions Subscription[]
  emailActivity EmailActivity[]
  @@map("subscription_plans")
}
model Subscription {
  id String @id @db.Uuid @default(uuid()) @map("id")
  userId String @db.Uuid @map("user_id")
  planId String @db.Uuid @map("plan_id")
  gatewaySubscriptionId String? @db.Text @unique @map("gateway_subscription_id")
  currentUsageCount Int @db.Integer @map("current_usage_count")
  startDate DateTime @default(now()) @map("start_date")
  endDate DateTime @map("end_date")
  isActive Boolean @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  user User @relation(fields: [userId],references: [id])
  plan SubscriptionPlan @relation(fields: [planId], references: [id])
  payments Payment[]
  emailActivity EmailActivity[]
  @@map("subscriptions")
}

model Payment {
  id String @id @db.Uuid @default(uuid()) @map("id")
  userId String @db.Uuid @map("user_id")
  subscriptionId String @db.Uuid @map("subscription_id")
  amount Decimal @db.Decimal(10,2) @map("amount")
  status PaymentStatus @default(PENDING) @map("status")
  gatewayOrderId String? @unique @db.Text @map("gateway_order_id")
  gatewayPaymentId String? @unique @db.Text @map("gateway_payment_id")
  gatewaySignature String? @db.Text @map("gateway_signature")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user User @relation(fields: [userId],references: [id])
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("payments")
}

model EmailActivity {
  id String @db.Uuid @default(uuid()) @id @map("id")
  userId String @db.Uuid @map("user_id")
  calendarAccountId String @db.Uuid @map("calendar_account_id")
  emailAccountId String @db.Uuid @map("email_account_id")
  planId String @db.Uuid @map("plan_id")
  subscriptionId String @db.Uuid @map("subscription_id")
  messageId String @db.Text @map("message_id")
  action String @db.Text @map("action")
  reason String? @db.Text @map("reason")
  isCompleted Boolean @db.Boolean @map("is_completed")
  processedAt DateTime @default(now()) @map("processed_at")
  user User @relation(fields: [userId], references: [id])
  emailAccount EmailAccount @relation(fields: [emailAccountId],references: [id])
  plan SubscriptionPlan @relation(fields: [planId], references: [id])
  subscription Subscription @relation(fields: [subscriptionId], references: [id])
  actionItems ActionItem[] 
  @@map("email_activities")
}

enum AIResponseTone {
  CASUAL
  PROFESSIONAL
}
enum AIResponseToneLabel {
  Casual
  Professional
}
enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum BillingInterval {
  MONTH
  YEAR
  TRIAL
}

model Enquiry {
  id String @db.Uuid @default(uuid()) @id @map("id")
  fullName String @db.VarChar(200) @map("full_name")
  email String @db.VarChar(100) @map("email")
  phone String @db.VarChar(15) @map("phone")
  company String @db.VarChar(200) @map("company")  
  message String @db.Text @map("message")
  createdAt DateTime @default(now()) @map("created_at")
  @@map("enquiries")
}

model AITone {
  id String @db.Uuid @default(uuid()) @id @map("id")
  tone AIResponseTone @default(PROFESSIONAL) @map("tone")
  label AIResponseToneLabel @default(Professional) @map("label")
  isActive Boolean @db.Boolean @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  @@map("ai_tones")
}

model AIService {
  id String @db.Uuid() @default(uuid()) @id @map("id")
  name String @db.VarChar(100) @unique @map("name")  
  isActive Boolean @db.Boolean @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  @@map("ai_services")
}
model ActionItem {
  id              String           @id @default(uuid()) @db.Uuid @map("id")
  emailActivityId String           @db.Uuid @map("email_activity_id")
  summary         String           @db.VarChar(300) @map("summary")
  deadline        DateTime?        @map("deadline")
  priority        ActionItemPriority @map("priority")
  status          ActionItemStatus @default(PENDING) @map("status")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  emailActivity   EmailActivity    @relation(fields: [emailActivityId], references: [id], onDelete: Cascade)

  @@index([emailActivityId])
  @@map("action_items")
}

enum ActionItemPriority {
  HIGH
  MEDIUM
  LOW
}

enum ActionItemStatus {
  PENDING
  DONE
  DISMISSED
}